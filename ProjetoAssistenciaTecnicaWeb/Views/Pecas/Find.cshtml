@model IEnumerable<ProjetoAssistenciaTecnicaWeb.Models.Peca>

@{
    ViewData["Title"] = "Busca";
}

<h2>@ViewData["Title"]</h2>

<p>
    <a asp-action="Create">Criar Novo</a>
</p>

<nav class="navbar navbar-inverse">
    <div class="container-fluid">
        <form class="navbar-form navbar-left" role="search">
            <div class="form-group">
                <div class="form-group">
                    <label for="descricao">Descricao</label>
                    <input type="text" class="form-control" name="descricao" value=@ViewData["descricao"] />
            </div>
            <button type="submit" class="btn btn-primary">Filtrar</button>
        </form>
    </div>
</nav>
<div class="panel panel-primary">
    <div class="panel-body">
        <table class="table table-striped table-hover">
            <thead>
                <tr class="success">
                    <th>
                        @Html.DisplayNameFor(model => model.Codigo)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Descricao)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.ValorCompra)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.ValorRevenda)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Quantidade)
                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @Html.DisplayFor(modelItem => item.Codigo)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Descricao)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.ValorCompra)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.ValorRevenda)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Quantidade)
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.IdPeca">Editar</a>
                            <a asp-action="Details" asp-route-id="@item.IdPeca">Detalhes</a>
                            <a asp-action="Delete" asp-route-id="@item.IdPeca">Excluir</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>