@{
}
@section Styles {
    <link rel="stylesheet" href="~/css/ordem.css" />
}

<div class="pagina-principal">

    <!-- FORM 1 -->
    <div class="pagina">
        <form class="formulario">

            <div class="general-infos">

                <div class="personal-info">
                    <label for="cpf">CPF:</label>
                    <input type="text" id="cpf">
                </div>

                <div class="personal-info">
                    <label for="nome">Nome:</label>
                    <input type="text" id="nome">
                </div>

                <div class="personal-info">
                    <label for="telefone">Telefone:</label>
                    <input type="text" id="telefone" placeholder="(__) ____-____">
                </div>

                <!-- CEP -->
                <div class="linha-cep">
                    <div class="campo">
                        <label for="cep">CEP:</label>
                        <input type="text" id="cep" placeholder="_____-___">
                    </div>

                    <button type="button" class="botao-cep">Buscar</button>
                </div>

                <!-- Rua e número -->
                <div class="linha-endereco">
                    <div class="campo">
                        <label for="rua">Rua:</label>
                        <input type="text" id="rua">
                    </div>

                    <div class="campo">
                        <label for="numero">Nº:</label>
                        <input type="text" id="numero">
                    </div>
                </div>

                <!-- Bairro e UF -->
                <div class="linha-endereco">
                    <div class="campo">
                        <label for="bairro">Bairro:</label>
                        <input type="text" id="bairro">
                    </div>

                    <div class="campo">
                        <label for="uf">UF:</label>
                        <select id="uf">
                            <option></option>
                            <option>SC</option>
                            <option>PR</option>
                            <option>MG</option>
                        </select>
                    </div>
                </div>

                <!-- Município e complemento -->
                <div class="linha-endereco">
                    <div class="campo">
                        <label for="municipio">Município:</label>
                        <input type="text" id="municipio">
                    </div>

                    <div class="campo">
                        <label for="complemento">Complemento:</label>
                        <input type="text" id="complemento">
                    </div>
                </div>



            </div>

        </form>
    </div>

    <!-- FORM 2 -->
    <div class="pagina-ordem">
        <form class="formulario-ordem">

            <div class="general-infos-ordem">

                <div class="ordem-info">
                    <label for="descricao">Descrição:</label>
                    <textarea class="input-descricao" id="descricao"></textarea>
                </div>

                <div class="linhas-ordem">
                    <div class="ordem-info">
                        <label for="modelo">Modelo:</label>
                        <input type="text" id="modelo">
                    </div>

                    <div class="ordem-info">
                        <label for="n-serie">Numero Série:</label>
                        <input type="text" id="n-serie">
                    </div>
                </div>

                <div class="linhas-ordem">
                    <div class="ordem-info">
                        <label for="marca">Marca:</label>
                        <input type="text" id="marca">
                    </div>

                    <div class="ordem-info">
                        <label for="condicao">Condição:</label>
                        <input type="text" id="condicao">
                    </div>
                </div>

                <div class="linhas-ordem">
                    <div class="ordem-info">
                        <label for="acessorios">Acessorios:</label>
                        <input type="text" id="acessorios">
                    </div>

                    <div class="ordem-info">
                        <label for="valor">Valor Inicial:</label>
                        <input type="text" id="valor" placeholder="R$">
                    </div>
                </div>

                <div class="linhas-ordem">
                    <div class="ordem-info">
                        <label for="id">ID:</label>
                        <input class="input-id" type="text" id="id">
                    </div>

                </div>

                <div class="botoes">
                    <button type="submit" class="botao-editar">Editar</button>
                    <button type="submit" class="botao-deletar">Deletar</button>
                    <button type="submit" class="botao-salvar">Salvar</button>
                </div>

            </div>

        </form>
    </div>

</div>