<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Funcionários</title>
    <link rel="stylesheet" href="funcionarios.css">
</head>
<body>

    <div class="pagina">
        <form class="formulario">

            <div class="linha-principal">
                <div class="grupo-campo">
                    <label for="nome">Nome:</label>
                    <input type="text" id="nome">
                </div>

                <div class="grupo-campo">
                    <label for="cpf">CPF:</label>
                    <input type="text" id="cpf">
                </div>

                <div class="grupo-campo">
                    <label for="telefone">Telefone:</label>
                    <input type="text" id="telefone" placeholder="(__) ____-____">
                </div>

                <div class="grupo-campo">
                    <label for="data">Data Nascimento:</label>
                    <div class="linha-data">
                        <input type="text" id="data" placeholder="__/__/__">
                    </div>
                </div>

                <div class="grupo-campo">
                    <label for="email">Email:</label>
                    <input type="email" id="email">
                </div>


                <button type="submit" class="botao">Cadastrar</button>


                <div class="linha-endereco linha-cep">
                    <label for="cep">CEP:</label>
                    <input type="text" id="cep" placeholder="_____-___">
                    <button type="button" class="botao">Buscar</button>
                </div>

                <div class="linha-endereco">
                    <label for="rua">Rua:</label>
                    <input type="text" id="rua">

                    <label for="numero">Nº:</label>
                    <input type="text" id="numero">
                </div>

                <div class="linha-endereco">
                    <label for="bairro">Bairro:</label>
                    <input type="text" id="bairro">

                    <label for="uf">UF:</label>
                    <select id="uf">
                        <option></option>
                        <option>SP</option>
                        <option>RJ</option>
                        <option>MG</option>
                    </select>
                </div>

                <div class="linha-endereco">
                    <label for="municipio">Município:</label>
                    <input type="text" id="municipio">
                    <label for="complemento">Complemento:</label>
                    <input type="text" id="complemento">
                </div>
            </div>

        </form>
    </div>

</body>
</html>
