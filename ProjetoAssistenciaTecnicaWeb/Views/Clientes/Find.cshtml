@model IEnumerable<ProjetoAssistenciaTecnicaWeb.Models.Cliente>

@{
    ViewData["Title"] = "Busca";
}
@section Styles {
    <link rel="stylesheet" href="~/css/ClientesBuscar.css" />
}

    <div class="pagina-principal">
        <div class="pagina-menus">

        <h1 class="titulo">Clientes</h1>

        <div class="botoes-menus">
            <a asp-action="Create" class="botao-salvar">Criar Novo</a>
        </div>

            <form class="formulario" role="search">
                <div class="general-infos">
                    <div class="filtro-infos">
                        <label for="nome">Nome</label>
                        <input type="text" name="nome" value=@ViewData["nome"] />
                    </div>
                    <div class="filtro-infos">
                        <label for="nome">CPF</label>
                        <input type="text" name="cpf" value=@ViewData["cpf"] />
                    </div>
                    <div class="filtro-infos">
                        <label for="nome">Telefone</label>
                        <input type="text" name="telefone" value=@ViewData["telefone"] />
                    </div>
                </div>
                <button type="submit" class="botao-buscar">Filtrar</button>
            </form>
        </div>
    </div>
<div class="panel panel-primary">
    <div class="panel-body">
        <table class="table table-striped table-hover">
            <thead>
                <tr class="success">
                    <th>
                        @Html.DisplayNameFor(model => model.Nome)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.CPF_CNPJ)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Telefone)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Email)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.DataNascimento)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.DataCadastro)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Funcionario.Nome)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Endereco.Municipio)
                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @Html.DisplayFor(modelItem => item.Nome)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.CPF_CNPJ)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Telefone)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Email)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.DataNascimento)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.DataCadastro)
                        </td>
                        <td>
                            Id: @item.FuncionarioId <br />
                            Nome: @(item.Funcionario == null ? "NULL" : item.Funcionario.Nome)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Endereco.Municipio)
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.IdCliente">Editar</a>
                            <a asp-action="Details" asp-route-id="@item.IdCliente">Detalhes</a>
                            <a asp-action="Delete" asp-route-id="@item.IdCliente">Excluir</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>