@model IEnumerable<ProjetoAssistenciaTecnicaWeb.Models.Produto>

@{
    ViewData["Title"] = "Busca";
}

@section Styles {
    <link rel="stylesheet" href="~/css/ProdutoBuscar.css" />
}

<nav class="pagina-principal">
    <div class="pagina-menus">

        <h1 class="titulo">Produtos</h1>

        <div class="botoes-menus">
            <a asp-action="Create" class="botao-salvar">Criar Novo</a>
        </div>

        <form class="formulario" role="search">
            <div class="general-infos">
                <div class="filtro-infos">
                        <label for="modelo">Modelo</label>
                        <input type="text" class="form-control" name="modelo" value=@ViewData["modelo"] />
                    </div>
                </div>
            <button type="submit" class="botao-buscar">Filtrar</button>
            </form>
    </div>
</nav>
<div class="panel panel-primary">
    <div class="panel-body">
        <table class="table table-striped table-hover">
            <thead>
                <tr class="success">
                    <th>
                        @Html.DisplayNameFor(model => model.Marca)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Modelo)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.NSerie)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Condicao)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Cliente.Nome)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Cliente.CPF_CNPJ)
                    </th>
                    <th>
                        <a href="#">Funcionário Cadastro</a>
                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @Html.DisplayFor(modelItem => item.Marca)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Modelo)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.NSerie)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Condicao)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Cliente.Nome)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Cliente.CPF_CNPJ)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Funcionario.Nome)
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.IdProduto">Editar</a>
                            <a asp-action="Details" asp-route-id="@item.IdProduto">Detalhes</a>
                            <a asp-action="Delete" asp-route-id="@item.IdProduto">Excluir</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>