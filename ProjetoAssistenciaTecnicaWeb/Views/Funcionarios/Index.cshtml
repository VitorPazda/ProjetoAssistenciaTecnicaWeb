﻿@{
    ViewData["Title"] = "Pesquisa";
}

@section Styles {
    <link rel="stylesheet" href="~/css/FuncionariosIndex.css" />
}

<div class="pagina-principal">

    <div class="pagina_menus">

        <h1 class="titulo">Pesquisa</h1>

        <div class="botoes-menus">
            <a asp-action="Create" class="botao-salvar">Criar Novo</a>
            <a asp-action="Edit" class="botao-editar">Editar</a>
            <a asp-action="Delete" class="botao-deletar">Deletar</a>
        </div>
        <form class="formulario">

            <div class="general-infos">

                <div class="filtro-infos">
                    <label for="nome">Nome:</label>
                    <input type="text" id="nome">
                </div>

                <div class="filtro-infos">
                    <label for="CPF">CPF:</label>
                    <input type="text" id="cpf">
                </div>

                <div>
                    <button class="botao-filtro">Filtrar</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}