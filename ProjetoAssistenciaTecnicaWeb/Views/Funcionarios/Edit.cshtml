@model ProjetoAssistenciaTecnicaWeb.Models.ViewModels.FuncionarioFormViewModel

@{
    ViewData["Title"] = "Editar";
}

<h1>Edit</h1>

<h4>Funcionario</h4>
<hr/>
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <input type="hidden" asp-for="Funcionario.IdFuncionario" />
            <input type="hidden" asp-for="Endereco.IdEndereco" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Funcionario.Nome" class="control-label"></label>
                <input asp-for="Funcionario.Nome" class="form-control" />
                <span asp-validation-for="Funcionario.Nome" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Funcionario.CPF_CNPJ" class="control-label"></label>
                <input asp-for="Funcionario.CPF_CNPJ" class="form-control" />
                <span asp-validation-for="Funcionario.CPF_CNPJ" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Funcionario.Telefone" class="control-label"></label>
                <input asp-for="Funcionario.Telefone" class="form-control" />
                <span asp-validation-for="Funcionario.Telefone" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Funcionario.Email" class="control-label"></label>
                <input asp-for="Funcionario.Email" class="form-control" />
                <span asp-validation-for="Funcionario.Email" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Funcionario.DataNascimento" class="control-label"></label>
                <input asp-for="Funcionario.DataNascimento" class="form-control" />
                <span asp-validation-for="Funcionario.DataNascimento" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Endereco.Estado" class="control-label"></label>
                <input asp-for="Endereco.Estado" class="form-control" />
                <span asp-validation-for="Endereco.Estado" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Endereco.Municipio" class="control-label"></label>
                <input asp-for="Endereco.Municipio" class="form-control" />
                <span asp-validation-for="Endereco.Municipio" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Endereco.Cep" class="control-label"></label>
                <input asp-for="Endereco.Cep" class="form-control" />
                <span asp-validation-for="Endereco.Cep" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Endereco.Rua" class="control-label"></label>
                <input asp-for="Endereco.Rua" class="form-control" />
                <span asp-validation-for="Endereco.Rua" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Endereco.Bairro" class="control-label"></label>
                <input asp-for="Endereco.Bairro" class="form-control" />
                <span asp-validation-for="Endereco.Bairro" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Endereco.Complemento" class="control-label"></label>
                <input asp-for="Endereco.Complemento" class="form-control" />
                <span asp-validation-for="Endereco.Complemento" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Endereco.NCasa" class="control-label"></label>
                <input asp-for="Endereco.NCasa" class="form-control" />
                <span asp-validation-for="Endereco.NCasa" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Edit" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Voltar</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
