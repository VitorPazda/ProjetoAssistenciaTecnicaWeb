<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ProjetoAssistenciaTecnicaWeb</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProjetoAssistenciaTecnicaWeb.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=menu" />
</head>
<body>
        <div class="layout">

            <aside class="sidebar" id="sidebar">

                <button type="button" class="toggle-btn" id="toggleSidebar" >
                <span class="material-symbols-outlined">
                    menu_open
                </span>
                </button>

                <div class="logo">
                    <span class="menu-title" >MENU irmao</span>
                </div>

                <ul class="nav flex-column">

                    <!-- CADASTRO -->
                    <li class="nav-item">
                        <a class="nav-link"
                               data-bs-toggle="collapse"
                               href="#Cadastro"
                               data-bs-title="Cadastro">

                            <span class="menu-icon">C</span>
                            <span class="menu-icon">C</span>
                            <span class="menu-text">Cadastro</span>
                            <span class="arrow">▾</span>
                        </a>

                        <div class="collapse submenu" id="Cadastro">
                            <ul class="nav flex-column">
                                <li><a asp-controller="Home" asp-action="Funcionarios" class="nav-link submenu-link">Funcionários</a></a></li>
                                <li><a href="clientes.html" class="nav-link submenu-link">Clientes</a></li>
                                <li><a href="produtos.html" class="nav-link submenu-link">Produtos</a></li>
                                <li><a href="pecas.html" class="nav-link submenu-link">Peças</a></li>
                            </ul>
                        </div>
                    </li>

                    <!-- VENDAS -->
                    <li class="nav-item">
                        <a class="nav-link"
                               data-bs-toggle="collapse"
                               href="#Vendas"
                               data-bs-title="Vendas">

                            <span class="menu-icon">V</span>
                            <span class="menu-text">Vendas</span>
                            <span class="arrow">▾</span>
                        </a>

                        <div class="collapse submenu" id="Vendas">
                            <ul class="nav flex-column">
                                <li><a href="orcamentos.html" class="nav-link submenu-link">Orçamentos</a></li>
                                <li><a href="pedidos.html" class="nav-link submenu-link">Pedidos</a></li>
                            </ul>
                        </div>
                    </li>

                </ul>
            </aside>

            <main class="conteudo-principal">
                <iframe id="areaPagina" src="" frameborder="0"></iframe>
            </main>

        </div>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
</body>
</html>
