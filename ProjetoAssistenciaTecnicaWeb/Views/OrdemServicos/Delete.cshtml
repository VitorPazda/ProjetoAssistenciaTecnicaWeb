@model ProjetoAssistenciaTecnicaWeb.Models.OrdemServico

@{
    ViewData["Title"] = "Delete";
}
@section Styles {
    <link rel="stylesheet" href="~/css/OrdemDelete.css" />
}


<h1>Excluir</h1>

<h3>Você tem certeza?</h3>
<div class="pagina">
    <h4>Ordem de Serviço</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Tick)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Tick)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.NumeroAtendimento)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.NumeroAtendimento)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Defeito)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Defeito)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.DataAbertura)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.DataAbertura)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Acessorios)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Acessorios)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Status)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Status)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Cliente.Nome)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Cliente.Nome)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Cliente.CPF_CNPJ)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Cliente.CPF_CNPJ)
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="IdOrdemServico"/>
        <input type="submit" value="Delete" class="btn btn-danger"/>
        <a asp-action="Index">Voltar</a>
    </form>
</div>
