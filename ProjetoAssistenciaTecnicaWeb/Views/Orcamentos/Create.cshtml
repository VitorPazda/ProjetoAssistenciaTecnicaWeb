@model ProjetoAssistenciaTecnicaWeb.Models.ViewModels.OrcamentoFormViewModel

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Orçamento</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Orcamento.Valor" class="control-label"></label>
                <input asp-for="Orcamento.Valor" class="form-control" />
                <span asp-validation-for="Orcamento.Valor" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Orcamento.FuncionarioId"></label>

                <select asp-for="Orcamento.FuncionarioId"
                        asp-items='@(new SelectList(Model.Funcionarios, "IdFuncionario", "Nome"))'
                        class="form-control">
                    <option value="">Selecione um funcionário</option>
                </select>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Voltar</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
