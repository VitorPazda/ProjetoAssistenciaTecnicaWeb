@model IEnumerable<ProjetoAssistenciaTecnicaWeb.Models.Orcamento>

@{
    ViewData["Title"] = "Busca";
}

<h2>@ViewData["Title"]</h2>

<p>
    <a asp-action="Create">Criar Novo</a>
</p>

<nav class="navbar navbar-inverse">
    <div class="container-fluid">
        <form class="navbar-form navbar-left" role="search">
            <div class="form-group">
                <div class="form-group">
                    <label for="codigoOrcamento">Codigo</label>
                    <input type="text" class="form-control" name="codigoOrcamento" value=@ViewData["codigoOrcamento"] />
                </div>
            </div>
            <button type="submit" class="btn btn-primary">Filtrar</button>
        </form>
    </div>
</nav>
<div class="panel panel-primary">
    <div class="panel-body">
        <table class="table table-striped table-hover">
            <thead>
                <tr class="success">
                    <th>
                        @Html.DisplayNameFor(model => model.CodigoOrcamento)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Valor)
                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @Html.DisplayFor(modelItem => item.CodigoOrcamento)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Valor)
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.IdOrcamento">Editar</a>
                            <a asp-action="Details" asp-route-id="@item.IdOrcamento">Detalhes</a>
                            <a asp-action="Delete" asp-route-id="@item.IdOrcamento">Excluir</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>